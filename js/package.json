{
  "name": "scopemask",
  "version": "1.0.0",
  "description": "Scope-bound opaque id masking for integers, strings, and UUIDs.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "sqids": "^0.3.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^2"
  }
}
